(deflayer eng_alphabet

         esc q l d w b         j f o  u  XX del
        lctl n r t s g         y h a  e  i  bspc
         tab z x m c v         k p XX XX XX XX

   @_sw_eng @_sw_rus lsft @_eng_sy spc     ent @_eng_na alt XX XX
)

(deflayer rus_alphabet

      esc @_СЋ @_Сѓ @_Р° @_Р· @_С€      @_С† @_С‡ @_Рґ @_Рє @_Р№ del
@_rus_shc @_Рµ @_Рё @_Рѕ @_СЃ @_Р¶      @_С… @_СЂ @_С‚ @_РЅ @_РІ bspc
      tab @_СЏ @_СЊ @_С‹ @_Рі @_СЌ      @_С„ @_Р» @_Рј @_Рї @_Р± XX

   @_sw_eng @_sw_rus lsft @_rus_sy spc  ent @_rus_na @_rus_sup XX XX
)

(deflayer rus_alphabet_sup

     esc XX      XX      XX XX @_С‰_sup     XX XX XX XX XX del
    lctl @_С‘_sup XX      XX XX XX          XX XX XX XX XX bspc
     tab XX      @_СЉ_sup XX XX XX          XX XX XX XX XX XX

	             XX XX lsft XX spc        ent XX XX XX XX
)

(deflayer rus_shortcut

         esc XX XX XX XX XX         XX f  XX XX XX del
          XX XX XX XX s  XX         XX XX a  XX XX bspc
         tab z  x  XX c  v          XX XX XX XX XX XX

           XX XX lsft XX spc       ent @_rus_na alt XX XX
)

