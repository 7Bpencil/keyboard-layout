)
(defalias
  _С‰_sup (multi (release-key alt) @_С‰)
  _СЉ_sup (multi (release-key alt) @_СЉ)
  _С‘_sup (multi (release-key alt) @_С‘)
)
(defalias
  _eng_! S-1
  _rus_! S-1
