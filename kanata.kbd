(deflayer eng_symbols

        esc @_eng_` @_eng_$ @_eng_| @_eng_& @_eng_#        @_eng_] @_eng_[ @_eng_{ @_eng_} @_eng_' del
       lctl @_eng__ @_eng_: @_eng_= @_eng_, @_eng_?        @_eng_! @_eng_. @_eng_вёЁ @_eng_вё© @_eng_; bspc
        tab @_eng_@ @_eng_% @_eng_* @_eng_/ @_eng_\        @_eng_+ @_eng_- @_eng_< @_eng_> @_eng_вЂњ XX

                                  XX XX lsft XX spc        ent XX alt @_eng_^ @_eng_~
)

(deflayer rus_symbols

        esc @_rus_` @_rus_$ @_rus_| @_rus_& @_rus_#        @_rus_] @_rus_[ @_rus_{ @_rus_} @_rus_' del
       lctl @_rus__ @_rus_: @_rus_= @_rus_, @_rus_?        @_rus_! @_rus_. @_rus_вёЁ @_rus_вё© @_rus_; bspc
        tab @_rus_@ @_rus_% @_rus_* @_rus_/ @_rus_\        @_rus_+ @_rus_- @_rus_< @_rus_> @_rus_вЂњ XX

                                  XX XX lsft XX spc        ent XX alt @_rus_^ @_rus_~
)
