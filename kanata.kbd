  _rus_^  XX
  _eng_& S-7
  _rus_&  XX
  _eng_* S-8
  _rus_* S-8
  _eng_вёЁ S-9 ;; (
  _rus_вёЁ S-9 ;; (
  _eng_вё© S-0 ;; )
  _rus_вё© S-0 ;; )
  _eng_-   -
  _rus_-   -
