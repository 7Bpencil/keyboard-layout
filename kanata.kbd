(defsrc
         esc q w e r t        y u i o p    del
        lctl a s d f g        h j k l scln bspc
         tab z x c v b        n m , . apos rsft

          1 2 lsft 4 spc    ent 7 alt 9 0
)

(defalias
  _eng     (layer-switch     eng_alphabet)
  _eng_na  (layer-while-held eng_numpad_arrows)
  _eng_sy  (layer-while-held eng_symbols)
  _rus     (layer-switch     rus_alphabet)
  _rus_sup (multi lalt (layer-while-held rus_alphabet_sup))
  _rus_na  (layer-while-held rus_numpad_arrows)
  _rus_sy  (layer-while-held rus_symbols)
  _rus_shc (multi lctl (layer-while-held rus_shortcut))
  _sw_eng  (multi lsft lalt 0 @_eng) ;; do not forget to setup it in OS
  _sw_rus  (multi lsft lalt 1 @_rus) ;; do not forget to setup it in OS
)
